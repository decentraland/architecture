digraph G { 
    label="Decentraland Architecture" 
    labelloc="t"
    fontsize=30
    fontname="Helvetica,Arial,sans-serif"
    compound=true; 
    
    node [fontname="Helvetica,Arial,sans-serif"]
    edge [fontname="Helvetica,Arial,sans-serif"]    
    graph [        
        newrank=true,             
        nodesep=0.5,
        ranksep=0.4,		
        splines=true,        
    ]
    node [        
        fixedsize=false,
        fontsize=21,
        height=1,
        shape=box,
        colorscheme="pubugn9",
        style="filled,setlinewidth(2)",       
        fillcolor=1,
        width=2
    ]
    
    subgraph cluster_client {     
        fontsize=24.0;
        colorscheme="pubugn9";       
        bgcolor=4;                
        label = <Unity Explorer <BR/> <FONT POINT-SIZE="15">Decentralized Client</FONT>>;          
        ExplorerClient [
            label=<Explorer<FONT POINT-SIZE="10"><BR/><BR/>Client</FONT>>;            
        ]       
    }

    ExplorerClient -> RealmProvider [label=" "]; 
    ExplorerClient -> Stats [label=" "];
    ExplorerClient -> Gatekeeper [label=" "];
    ExplorerClient -> Auth [label=" "]; 
    ExplorerClient -> PlacesAPI [label=" "];
    ExplorerClient -> AssetBundleRegistry [label = " "];
    ExplorerClient -> EventsNotifier [label=" "];
    ExplorerClient -> Notifications [label=" "];
    ExplorerClient -> Badges [label=" "];
    ExplorerClient -> CameraReel [label=" "];
    ExplorerClient -> SocialService [label=" "];
    ExplorerClient -> ExplorationGames [label=" "];
    ExplorerClient -> Events [label=" "];
    ExplorerClient -> Worlds [label=" "];

    
    PlacesAPI [
        label=<Places API<BR/> <FONT POINT-SIZE="10">Places API</FONT>>;
        URL="https://github.com/decentraland/places";
    ]    
    RealmProvider [
        label=<Realm Provider<BR/> <FONT POINT-SIZE="10">Realm Services Description</FONT>>;
        URL="https://github.com/decentraland/realm-provider";
    ]
    AssetBundleRegistry [
        label=<Asset Bundle Registry<BR/> <FONT POINT-SIZE="10">Asset Bundles</FONT>>;
        URL="https://github.com/decentraland/asset-bundle-registry";
    ]
    AssetBundleConverter [
        label=<Asset Bundle Converter<BR/> <FONT POINT-SIZE="10">Builds Asset Bundles for all platforms</FONT>>;
        URL="https://github.com/decentraland/asset-bundle-converter";
    ]
    EventsNotifier [
        label=<Events Notifier<BR/> <FONT POINT-SIZE="10">User Events</FONT>>;
        URL="https://github.com/decentraland/notifications-workers";
    ]
    Notifications [
        label=<Notifications Inbox<BR/> <FONT POINT-SIZE="10">User Notifications</FONT>>;
        URL="https://github.com/decentraland/notifications-workers";
    ]
    NotificationsProcessor [
        label=<Notifications Processor<BR/> <FONT POINT-SIZE="10">Generate user Notifications</FONT>>;
        URL="https://github.com/decentraland/notifications-workers";
    ]
    SendGrid [
        label=<SendGrid (SaaS)<BR/> <FONT POINT-SIZE="10">Cloud Service to send emails</FONT>>;
        URL="https://github.com/decentraland/notifications-workers";
    ]
    Badges [
        label=<Badges<BR/> <FONT POINT-SIZE="10">User Badges</FONT>>;
        URL="https://github.com/decentraland/badges";
    ]
    BadgesProcessor [
        label=<Badges Processor<BR/> <FONT POINT-SIZE="10">Grant Badges to Users</FONT>>;
        URL="https://github.com/decentraland/badges";
    ]
    CameraReel [
        label=<Camera Reel<BR/> <FONT POINT-SIZE="10">Camera Reel</FONT>>;
        URL="https://github.com/decentraland/camera-reel-service";
    ]
    SocialService [
        label=<Social Service<BR/> <FONT POINT-SIZE="10">Friends</FONT>>;
        URL="https://github.com/decentraland/social-service-ea";
    ]
    ExplorationGames [
        label=<Exploration Games<BR/> <FONT POINT-SIZE="10">Onboarding Games</FONT>>;
        URL="https://github.com/decentraland/social-service-ea";
    ]
    Worlds [
        label=<Worlds Content Server<BR/> <FONT POINT-SIZE="10">Isolated Scenes</FONT>>;
        URL="https://github.com/decentraland/worlds-content-server";
    ]
    Events [
        label=<Events API<BR/> <FONT POINT-SIZE="10">Decentraland Events</FONT>>;
        URL="https://github.com/decentraland/events";
    ]
    Rewards [
        label=<Rewards API<BR/> <FONT POINT-SIZE="10">Grant NFT Rewards</FONT>>;
        URL="https://github.com/decentraland/referral";
    ]
    LiveKit [
        label=<LiveKit (SaaS)<BR/> <FONT POINT-SIZE="10">High Quality Media Server</FONT>>;
        URL="https://livekit.io/";
    ]               
    Stats [
        label=<Communications Stats<BR/> <FONT POINT-SIZE="10">Users Stats</FONT>>;
        URL="https://github.com/decentraland/archipelago-workers";
    ]     
    WorkerSubgraph[
        label=<Subgraph<BR/> <FONT POINT-SIZE="10">Query Blockchain</FONT>>;
        URL="https://github.com/decentraland/lamb2";
    ]           
    
    Deployments [
        label=<Deployments to SQS<BR/> <FONT POINT-SIZE="10">Deployments Listener</FONT>>;
        URL="https://github.com/decentraland/deployments-to-sqs";
    ]

    NATS [
        label=<NATS<BR/> <FONT POINT-SIZE="10">Message Broker</FONT>>;
        URL="https://nats.io/";
    ]    
    Auth [
        label=<Auth<BR/> <FONT POINT-SIZE="10">Authentication Service</FONT>>;
        URL="https://github.com/decentraland/auth";
    ]
    Gatekeeper [
        label=<Communications Gatekeeper<BR/> <FONT POINT-SIZE="10">Livekit Gatekeeper</FONT>>;
        URL="https://github.com/decentraland/comms-gatekeeper";
    ]
    CatalystClient [
        label=<Catalyst Client<BR/> <FONT POINT-SIZE="10">Library to interact with Catalyst Servers</FONT>>;
        URL="https://github.com/decentraland/catalyst-client";
    ]
    ProfileImages [
        label=<Profile Images<BR/> <FONT POINT-SIZE="10">Generate Avatar images</FONT>>;
        URL="https://github.com/decentraland/profile-images";
    ]

    subgraph cluster_catalyst {
        label = <Catalyst <BR/> <FONT POINT-SIZE="15">Decentralized Servers</FONT>>;
        colorscheme="pubugn9";
        bgcolor=4;
        fontsize=24.0;
        URL="https://github.com/decentraland/catalyst-owner";
        
        Nginx [
            label=<Nginx<BR/> <FONT POINT-SIZE="10">Reverse Proxy</FONT>>;
        ]      
        Content [
            label=<Content Server<BR/> <FONT POINT-SIZE="10">Assets Storage</FONT>>;
            URL="https://github.com/decentraland/catalyst";
        ]        
        Lambdas [
            label=<Lambdas<BR/> <FONT POINT-SIZE="10">Catalyst Lambdas</FONT>>;
            URL="https://github.com/decentraland/lamb2";
        ]
        CAdvisor [
            label=<CAdvisor<BR/> <FONT POINT-SIZE="10">Container Monitor</FONT>>;
        ]                           
        Nginx -> Lambdas [style=invis];    
        Content -> CAdvisor [style=invis];                     
    }

     subgraph cluster_archipelago_workers {
        label = <Archipelago Workers<BR/> <FONT POINT-SIZE="15">Comms Services</FONT>>;
        colorscheme="pubugn9";
        bgcolor=4;
        fontsize=24.0;
        URL="https://github.com/decentraland/archipelago-workers";
        
        WebSocket [
            label=<WebSocket Connector<BR/> <FONT POINT-SIZE="10">WebSocket Connections Provider</FONT>>;
            URL="https://nats.io/";
        ]    
        ArchipelagoCore [
            label=<Archipelago Core<BR/> <FONT POINT-SIZE="10">Peers clustering logic</FONT>>;
            URL="https://nats.io/";
        ]     
        WebSocket -> ArchipelagoCore [style=invis];  
    }

    subgraph cluster_cli { 
        label = <CLI<BR/><FONT POINT-SIZE="10"><BR/>Command line to start new projects,<BR/>preview changes and deploy<BR/>scenes and smart items</FONT>>;
        colorscheme="pubugn9";       
        bgcolor=4;
        fontsize=24.0;              
        edge [arrowhead=none, dir=none];
        
        CLI [
            label=<CLI<BR/> <FONT POINT-SIZE="10"><BR/>Compiles scenes (build-ecs)<BR/>Preview scenes in browser<BR/>Uploads compiled code to catalys</FONT>>;
            URL="https://github.com/decentraland/cli";
        ]
        "build-ecs" [
            label=<build-ecs<FONT POINT-SIZE="10"><BR/>Bundles code from scenes, AMD and ECS<BR/>to generate deployable scenes</FONT>>;            
            URL="https://github.com/decentraland/js-sdk-toolchain/blob/c648dcabc0ac1aade3cf143769f7e7f67ffba95b/packages/%40dcl/build-ecs/index.ts";
        ]
        CLI -> "build-ecs";
    }

    Content -> Deployments;
    Content -> WorkerSubgraph;         
    Deployments -> AssetBundleConverter; 
    AssetBundleConverter -> AssetBundleRegistry;  
    Lambdas -> ProfileImages; 
    ProfileImages -> Deployments; 
    
    ArchipelagoCore -> NATS [dir=both, ltail=cluster_archipelago_workers];
    ArchipelagoCore -> LiveKit;    
    Stats -> NATS;    
    Gatekeeper -> LiveKit;         
    Gatekeeper -> Deployments;  
    Gatekeeper -> Worlds;  
    Gatekeeper -> PlacesAPI;
    Gatekeeper -> EventsNotifier;
    Worlds -> LiveKit;
    Auth -> Nginx [label=" ", lhead=cluster_catalyst];     
    RealmProvider -> Lambdas [label=" ", lhead=cluster_catalyst];           
    RealmProvider -> WebSocket [label=" ", lhead=cluster_archipelago_workers];                 
    Notifications -> SendGrid;
    EventsNotifier -> NotificationsProcessor; 
    EventsNotifier -> BadgesProcessor; 
    Notifications -> NotificationsProcessor; 
    Badges -> BadgesProcessor;
    ExplorationGames -> Rewards; 
    Rewards -> Stats;
    SocialService -> CatalystClient;
    SocialService -> NATS; 
    SocialService -> Stats; 
    CatalystClient -> Nginx [lhead=cluster_catalyst];     
    PlacesAPI -> Lambdas [lhead=cluster_catalyst];         
    Rewards -> WorkerSubgraph;
    Rewards -> EventsNotifier;
    Badges -> CatalystClient;   
    Worlds -> NATS;
    CLI -> CatalystClient[ltail=cluster_cli];

    {
        rank = same;        
        PlacesAPI;
        RealmProvider;
        Stats;
        Gatekeeper;
        Auth;
        AssetBundleRegistry;
        Notifications;
        Badges;
        CameraReel;
        SocialService;
        ExplorationGames;
        Events; 
    }      
    {
        rank = same;        
        CLI;
        Lambdas;
    }
    
}